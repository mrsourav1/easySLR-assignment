// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrgRole {
  OWNER
  MEMBER
}

enum ProjectRole {
  OWNER
  REVIEWER
}

enum ReviewStatus {
  UNREVIEWED
  INCLUDE
  EXCLUDE
  MAYBE
}

enum ImportStatus {
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String              @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  orgMemberships OrganizationMember[]
  projectMemberships ProjectMember[]
  reviewedArticles Article[]         @relation("ArticleReviewer")
  importRuns    ImportRun[]
}

model Organization {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  projects  Project[]
  members   OrganizationMember[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Project {
  id             String          @id @default(cuid())
  name           String
  description    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  articles       Article[]
  members        ProjectMember[]
  importRuns     ImportRun[]

  @@index([organizationId])
}

model ProjectMember {
  id        String      @id @default(cuid())
  role      ProjectRole @default(REVIEWER)
  createdAt DateTime    @default(now())
  userId    String
  projectId String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
}

model Article {
  id              String       @id @default(cuid())
  projectId       String
  pmid            String?
  title           String
  authors         String?
  citation        String?
  firstAuthor     String?
  journal         String?
  publicationYear Int?
  createDate      DateTime?
  pmcid           String?
  nihmsId         String?
  doi             String?
  reviewStatus    ReviewStatus @default(UNREVIEWED)
  priority        Int          @default(2)
  labels          String[]     @default([])
  reviewerNotes   String?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reviewedBy      User?        @relation("ArticleReviewer", fields: [reviewedById], references: [id])

  @@unique([projectId, pmid])
  @@unique([projectId, doi])
  @@index([projectId, reviewStatus])
  @@index([projectId, publicationYear])
}

model ImportRun {
  id             String       @id @default(cuid())
  projectId      String
  uploadedById   String
  fileName       String
  status         ImportStatus
  totalRows      Int
  insertedRows   Int
  skippedRows    Int
  errorRows      Int
  duplicateRows  Int
  validationJson Json
  createdAt      DateTime     @default(now())
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
